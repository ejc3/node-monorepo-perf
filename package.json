{
  "name": "pnpm-demo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.1",
  "description": "A 10,000-app / 300-library pnpm + Turborepo monorepo for measuring Next.js performance at scale",
  "scripts": {
    "gen": "node scripts/generate.mjs",
    "bench": "node scripts/measure.mjs",
    "chart": "node scripts/chart.mjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "graph": "turbo run build --dry=json"
  },
  "devDependencies": {
    "turbo": "2.9.18",
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
