{
  "name": "pnpm-demo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.1",
  "description": "A 10,000-app / 300-library pnpm + Turborepo monorepo for measuring Next.js performance at scale",
  "scripts": {
    "gen": "node scripts/generate.mjs",
    "bench": "node scripts/measure.mjs",
    "chart": "node scripts/chart.mjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "graph": "turbo run build --dry=json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "prettier": "^3.8.4",
    "turbo": "2.9.18",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
