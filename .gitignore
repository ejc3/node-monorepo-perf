# transient: a partial real-app-bench run (REAL_APP_ONLY / non-default samples) — never the record
/bench/real-app-bench.partial.json
# transient: an install-bench run at non-canonical scales, and a canonical run's in-progress
# persistence (promoted to install-bench.json only on completion) — never the record
/bench/install-bench.partial.json
# transient: a smoke editor-loop-bench run (fewer samples / non-default scales) — never the record
/bench/editor-loop-bench.partial.json
# transient: editor-loop-bench's tsconfig.base.json backup (removed on exit; self-heals a hard kill)
/tsconfig.base.json.bench.bak
