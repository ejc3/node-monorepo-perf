# --- pnpm performance knobs (toggled in the demo) ---

# isolated (default): strict, symlinked node_modules. Safest for a 10k-package
# graph. Switch to `hoisted` to trade strictness for fewer symlinks.
node-linker=isolated

# Don't prompt for dependency build scripts during non-interactive installs.
confirm-modules-purge=false

# Workspace packages always resolve to the local source, never the registry.
link-workspace-packages=true
prefer-workspace-packages=true

# Skip building optional native deps we don't need for the benchmark.
enable-pre-post-scripts=false
